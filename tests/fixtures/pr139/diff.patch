+  ```python
+  def read_core_trail() -> list[CoreTrailEntry]:
+      """Read core ETF trailing-stop state from the core_trail table.
+
+      Phase 1b #116 (2026-05-24): DB-canonical. Pre-#116 this parsed
+      memory/CORE-TRAIL.md directly; that markdown is now a rendered view.
+      """
+      from scripts.core_trail import TrailState, breach_status
+      from scripts.db import connect
+      with connect() as conn:
+          rows = conn.execute(
+              "SELECT symbol, ath_close, ath_close_date, last_observed,"
+              " last_observed_date, trail_pct, breach_date, re_entry_watch,"
+              " currency FROM core_trail ORDER BY symbol"
+          ).fetchall()
+      out: list[CoreTrailEntry] = []
+      for r in rows:
+          ath = float(r["ath_close"])
+          last = float(r["last_observed"])
+          pct = float(r["trail_pct"])
+          stop = ath * (1.0 - pct / 100.0)
+          status = breach_status(TrailState(ath_close=ath, stop=stop,
+                                            last_observed=last))
+          out.append(CoreTrailEntry(
+              symbol=r["symbol"],
+              ath_close=ath,
+              ath_close_date=r["ath_close_date"],
+              stop=stop,
+              last_observed=last,
+              last_observed_date=r["last_observed_date"],
+              status=status,
+              trail_pct=pct,
+              re_entry_watch=bool(r["re_entry_watch"]),
+              currency=r["currency"],
+          ))
+      return out
+  ```
