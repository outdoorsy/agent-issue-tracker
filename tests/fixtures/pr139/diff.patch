+++ b/tests/test_backfill_core_trail.py
@@ -0,0 +1,174 @@
+"""tests for scripts/backfill_core_trail.py -- one-shot markdown backfill."""
+from __future__ import annotations
+
+from pathlib import Path
+
+import pytest
+
+from scripts.backfill_core_trail import backfill, infer_currency, parse_markdown
+from scripts.db import connect
+
+
+_FIXTURE_MARKDOWN = """\
+# Core ETF Trailing Stop -- current state
+
+Per-ETF current-state file (rewritable, not append-only). Updated by
+`/check-triggers` on each daily run. One H2 section per held core ETF.
+
+## Per-ETF format
+
+```yaml
+ath_close: 0.00
+ath_close_date: 1970-01-01
+stop: 0.00
+last_observed: 0.00
+last_observed_date: 1970-01-01
+status: ok
+breach_date: null
+trail_pct: 20
+re_entry_watch: false
+```
+
+## VWCE.DE
+
+```yaml
+ath_close: 158.06
+ath_close_date: 2026-05-06
+stop: 126.448
+last_observed: 157.98
+last_observed_date: 2026-05-07
+status: ok
+breach_date: null
+trail_pct: 20
+re_entry_watch: false
+```
+
+## Behavior
+
+- `/check-triggers` reads this file once per run.
+"""
+
+
+def test_parse_markdown_skips_schema_sections(tmp_path: Path):
+    md = tmp_path / "CORE-TRAIL.md"
+    md.write_text(_FIXTURE_MARKDOWN, encoding="utf-8")
+    rows = parse_markdown(md)
+    # Per-ETF format and Behavior sections are NOT data rows.
+    assert len(rows) == 1
+    assert rows[0]["symbol"] == "VWCE.DE"
+
+
+def test_parse_markdown_extracts_all_fields(tmp_path: Path):
+    md = tmp_path / "CORE-TRAIL.md"
+    md.write_text(_FIXTURE_MARKDOWN, encoding="utf-8")
+    r = parse_markdown(md)[0]
+    assert r["symbol"] == "VWCE.DE"
