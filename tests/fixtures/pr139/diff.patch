+        "INSERT INTO core_trail(symbol, ath_close, ath_close_date,"
+        " last_observed, last_observed_date, trail_pct, breach_date,"
+        " re_entry_watch, currency, updated_at) "
+        "VALUES('TEST',100.0,'2026-01-01',100.0,'2026-01-01',20.0,NULL,0,'USD','2026-01-01T00:00:00Z')"
+    )
+    conn.commit()
+    conn.close()
+    # Second connect(): the row must SURVIVE. This is the regression
+    # guard against DROP-TABLE-on-every-connect inside _SCHEMA_SQL.
+    conn = connect(db)
+    n = conn.execute("SELECT COUNT(*) AS n FROM core_trail").fetchone()["n"]
+    assert n == 1, "second connect() wiped the table - migration is non-idempotent"
     conn.close()
 
 
