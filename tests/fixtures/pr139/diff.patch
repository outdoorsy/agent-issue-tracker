+
+def _core_trail_db_path() -> Path | None:
+    """Path passed to db.connect(). None means use the default DB_PATH."""
+    v = os.environ.get("CORE_TRAIL_DB")
+    return Path(v) if v else None
+
+
+def _core_trail_markdown_path() -> Path:
+    v = os.environ.get("CORE_TRAIL_MARKDOWN")
+    return Path(v) if v else DEFAULT_MARKDOWN
+
+
+def _now_iso() -> str:
+    return dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
+
+
+def _infer_currency(symbol: str) -> str:
+    for suffix in _EUR_SUFFIXES:
+        if symbol.endswith(suffix):
+            return "EUR"
+    return "USD"
+
+
+@dataclass(frozen=True)
+class CoreTrailRow:
+    symbol: str
+    ath_close: float
+    ath_close_date: str
+    last_observed: float
+    last_observed_date: str
+    trail_pct: float
+    breach_date: str | None
+    re_entry_watch: bool
+    currency: str
+    updated_at: str
+
+
+# Single source of truth for core_trail's column list. Used by every
+# SELECT in this module so a future column addition stays one-line.
+_TRAIL_COLS = (
+    "symbol, ath_close, ath_close_date, last_observed,"
+    " last_observed_date, trail_pct, breach_date, re_entry_watch,"
+    " currency, updated_at"
+)
+
+
+def _row_to_core_trail(r: sqlite3.Row) -> CoreTrailRow:
+    return CoreTrailRow(
+        symbol=r["symbol"],
+        ath_close=float(r["ath_close"]),
+        ath_close_date=r["ath_close_date"],
+        last_observed=float(r["last_observed"]),
+        last_observed_date=r["last_observed_date"],
+        trail_pct=float(r["trail_pct"]),
+        breach_date=r["breach_date"],
+        re_entry_watch=bool(r["re_entry_watch"]),
+        currency=r["currency"],
+        updated_at=r["updated_at"],
+    )
+
+
+def _trail_state_from_row(row: CoreTrailRow) -> TrailState:
+    """Build the pure-fn TrailState (with derived stop) from a persisted row.
+    Used by both the renderer and the CLI JSON output so the two paths
+    compute `status` from the same source."""
+    stop = row.ath_close * (1 - row.trail_pct / 100.0)
+    return TrailState(ath_close=row.ath_close, stop=stop,
+                      last_observed=row.last_observed)
+
+
+def read_state(conn: sqlite3.Connection, symbol: str) -> CoreTrailRow | None:
+    r = conn.execute(
+        f"SELECT {_TRAIL_COLS} FROM core_trail WHERE symbol=?", (symbol,),
+    ).fetchone()
+    return _row_to_core_trail(r) if r else None
+
+
+def write_state(
+    conn: sqlite3.Connection, *,
+    symbol: str,
+    ath_close: float,
+    ath_close_date: str,
+    last_observed: float,
+    last_observed_date: str,
+    trail_pct: float,
+    breach_date: str | None,
+    re_entry_watch: bool,
+    currency: str,
+) -> CoreTrailRow:
+    """Single-statement upsert in one transaction. Returns the persisted row."""
+    now = _now_iso()
+    with conn:
+        conn.execute(
+            "INSERT INTO core_trail(symbol, ath_close, ath_close_date,"
+            " last_observed, last_observed_date, trail_pct, breach_date,"
+            " re_entry_watch, currency, updated_at)"
+            " VALUES(?,?,?,?,?,?,?,?,?,?)"
+            " ON CONFLICT(symbol) DO UPDATE SET"
+            " ath_close=excluded.ath_close,"
+            " ath_close_date=excluded.ath_close_date,"
+            " last_observed=excluded.last_observed,"
+            " last_observed_date=excluded.last_observed_date,"
+            " trail_pct=excluded.trail_pct,"
+            " breach_date=excluded.breach_date,"
+            " re_entry_watch=excluded.re_entry_watch,"
+            " currency=excluded.currency,"
+            " updated_at=excluded.updated_at",
+            (symbol, float(ath_close), ath_close_date,
+             float(last_observed), last_observed_date,
+             float(trail_pct), breach_date,
+             1 if re_entry_watch else 0, currency, now),
+        )
+    row = read_state(conn, symbol)
+    if row is None:
+        # Defensive: read-after-write came back empty. assert would be
+        # stripped under python -O; raise a real exception instead.
+        raise RuntimeError(f"write_state: row for {symbol!r} missing after upsert")
+    return row
+
+
+def update_state(
+    conn: sqlite3.Connection, *,
+    symbol: str,
+    current_close: float,
+    observed_date: str,
+    trail_pct: float,
+    currency: str | None = None,
+) -> CoreTrailRow:
+    """Orchestrator: read existing row (or seed fresh), apply ratchet,
+    compute breach status, flip breach_date on transition into breached,
+    preserve re_entry_watch from existing row. Returns the new persisted row.
+
+    Raises ValueError on invalid trail_pct (delegated to update_trail)."""
+    existing = read_state(conn, symbol)
+    if existing is None:
+        # Seed: current_close is both the initial ATH and last_observed.
+        # Validate trail_pct via the pure-fn ratchet on a synthetic state.
+        seed = TrailState(ath_close=current_close,
+                          stop=current_close * (1 - trail_pct / 100.0),
+                          last_observed=current_close)
+        new = update_trail(seed, current_close, trail_pct)
+        status = breach_status(new)
+        breach_date = observed_date if status == "breached" else None
+        return write_state(
+            conn,
+            symbol=symbol,
+            ath_close=new.ath_close,
+            ath_close_date=observed_date,
+            last_observed=new.last_observed,
+            last_observed_date=observed_date,
+            trail_pct=trail_pct,
+            breach_date=breach_date,
+            re_entry_watch=False,
+            currency=currency or _infer_currency(symbol),
+        )
+    # Existing row: apply ratchet against existing state.
+    prev_state = TrailState(
+        ath_close=existing.ath_close,
+        stop=existing.ath_close * (1 - existing.trail_pct / 100.0),
+        last_observed=existing.last_observed,
+    )
+    new = update_trail(prev_state, current_close, trail_pct)
+    status = breach_status(new)
+    # ath_close_date only advances when ath itself advances.
+    ath_close_date = (observed_date if new.ath_close > existing.ath_close
+                      else existing.ath_close_date)
+    # breach_date is set on TRANSITION into breached; preserved otherwise.
+    if status == "breached":
+        breach_date = existing.breach_date or observed_date
+    else:
+        breach_date = existing.breach_date  # null or historical -- unchanged
+    return write_state(
+        conn,
+        symbol=symbol,
+        ath_close=new.ath_close,
+        ath_close_date=ath_close_date,
+        last_observed=new.last_observed,
+        last_observed_date=observed_date,
+        trail_pct=trail_pct,
+        breach_date=breach_date,
+        re_entry_watch=existing.re_entry_watch,
+        currency=currency or existing.currency,
+    )
+
+
+# --- Render-on-demand (Phase 1b #116) ----------------------------------
+
+_RENDER_INTRO = (
+    "Per-ETF current-state file. **DB-canonical: the `core_trail` table "
+    "is the source of truth. This markdown is rendered by "
+    "`python3 -m scripts.core_trail render` and must not be hand-edited.** "
+    "Updated by `/check-triggers` on each daily run via "
+    "`python3 -m scripts.core_trail update ...`. One H2 section per held core ETF.\n"
+)
+
+_RENDER_FORMAT = (
+    "```yaml\n"
+    "ath_close: 0.00            # All-time-high closing price (native currency)\n"
+    "ath_close_date: 1970-01-01\n"
+    "stop: 0.00                 # Derived: ath_close * (1 - trail_pct/100)\n"
+    "last_observed: 0.00\n"
+    "last_observed_date: 1970-01-01\n"
+    "status: ok                 # Derived: ok | approaching | breached\n"
+    "breach_date: null\n"
+    "trail_pct: 20\n"
+    "re_entry_watch: false\n"
+    "currency: EUR\n"
+    "```\n"
+)
+
+_RENDER_BEHAVIOR = (
+    "- `/check-triggers` reads the `core_trail` table once per run. For each\n"
+    "  held ETF:\n"
+    "  - Fetch latest close via `bash scripts/prices.sh {SYMBOL}`.\n"
+    "  - Update state via `python3 -m scripts.core_trail update ...` which\n"
+    "    writes the DB row and re-renders this file.\n"
+    "  - On status change `ok -> approaching`: notify softly (\"close $X, stop\n"
+    "    $Y, < 0.5% above\").\n"
+    "  - On status change `* -> breached`: notify loudly, set `re_entry_watch`\n"
+    "    to `true`, **do not place an order**. The user runs\n"
+    "    `/propose-trade {SYMBOL} sell <qty>` to act.\n"
+    "- Re-entry: while `re_entry_watch` is true, `/check-triggers` adds a\n"
+    "  context block to its report -- % off recent low, 200-DMA cross status,\n"
+    "  breadth proxy. The user clears `re_entry_watch` when they decide\n"
+    "  (either by re-buying or by explicitly leaving it off).\n"
+)
+
+
+def _render_row(row: CoreTrailRow) -> str:
+    state = _trail_state_from_row(row)
+    status = breach_status(state)
+    bd = row.breach_date if row.breach_date else "null"
+    rw = "true" if row.re_entry_watch else "false"
+    return (
+        f"## {row.symbol}\n"
+        "\n"
+        "```yaml\n"
+        f"ath_close: {row.ath_close:.2f}\n"
+        f"ath_close_date: {row.ath_close_date}\n"
+        f"stop: {state.stop:.2f}\n"
+        f"last_observed: {row.last_observed:.2f}\n"
+        f"last_observed_date: {row.last_observed_date}\n"
+        f"status: {status}\n"
+        f"breach_date: {bd}\n"
+        f"trail_pct: {row.trail_pct:g}\n"
+        f"re_entry_watch: {rw}\n"
+        f"currency: {row.currency}\n"
+        "```\n"
+    )
+
+
+def render(conn: sqlite3.Connection) -> str:
+    """Deterministic markdown render of all core_trail rows, ORDER BY symbol."""
+    rows = conn.execute(
+        f"SELECT {_TRAIL_COLS} FROM core_trail ORDER BY symbol"
+    ).fetchall()
+    parts: list[str] = [
+        "# Core ETF Trailing Stop -- current state\n",
+        "\n",
+        _RENDER_INTRO,
+        "\n",
+        "## Per-ETF format\n",
+        "\n",
+        _RENDER_FORMAT,
+    ]
+    for r in rows:
+        parts.append("\n")
+        parts.append(_render_row(_row_to_core_trail(r)))
+    parts.append("\n")
+    parts.append("## Behavior\n")
+    parts.append("\n")
+    parts.append(_RENDER_BEHAVIOR)
+    return "".join(parts)
+
+
+def render_to(conn: sqlite3.Connection, path: Path) -> None:
+    """Write render(conn) to `path`, UTF-8, LF line endings."""
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(render(conn), encoding="utf-8", newline="\n")
+
+
+# --- CLI ---------------------------------------------------------------
+
+def _row_to_json_dict(row: CoreTrailRow) -> dict:
+    state = _trail_state_from_row(row)
+    return {
+        "symbol": row.symbol,
+        "ath_close": row.ath_close,
+        "ath_close_date": row.ath_close_date,
+        "stop": round(state.stop, 2),
+        "last_observed": row.last_observed,
+        "last_observed_date": row.last_observed_date,
+        "status": breach_status(state),
+        "breach_date": row.breach_date,
+        "trail_pct": row.trail_pct,
+        "re_entry_watch": row.re_entry_watch,
+        "currency": row.currency,
+    }
+
+
+def update_cli(args: argparse.Namespace) -> int:
+    db_path = _core_trail_db_path()
+    conn = connect(db_path) if db_path else connect()
+    try:
+        row = update_state(
+            conn,
+            symbol=args.symbol,
+            current_close=args.close,
+            observed_date=args.date,
+            trail_pct=args.trail_pct,
+            currency=args.currency,
+        )
+        render_to(conn, _core_trail_markdown_path())
+    finally:
+        conn.close()
+    print(json.dumps(_row_to_json_dict(row)))
+    return 0
+
+
+def render_cli(args: argparse.Namespace) -> int:
+    db_path = _core_trail_db_path()
+    conn = connect(db_path) if db_path else connect()
+    try:
+        if args.write:
+            render_to(conn, _core_trail_markdown_path())
+        else:
+            sys.stdout.buffer.write(render(conn).encode("utf-8"))
+    finally:
+        conn.close()
+    return 0
+
+
+def main(argv: list[str] | None = None) -> int:
+    p = argparse.ArgumentParser(
+        description="core_trail: trailing-stop DB writer + markdown renderer."
+    )
+    sub = p.add_subparsers(dest="cmd", required=True)
+
+    up = sub.add_parser("update", help="apply one observation to a symbol's trail")
+    up.add_argument("--symbol", required=True)
+    up.add_argument("--close", type=float, required=True)
+    up.add_argument("--date", required=True, help="YYYY-MM-DD")
+    up.add_argument("--trail-pct", type=float, required=True)
+    up.add_argument("--currency", default=None,
+                    help="defaults to existing row's value, or EUR/USD heuristic")
+    up.set_defaults(func=update_cli)
+
+    rd = sub.add_parser("render", help="render memory/CORE-TRAIL.md from DB")
+    rd.add_argument("--write", action="store_true",
+                    help=f"write to {DEFAULT_MARKDOWN} (default: stdout)")
+    rd.set_defaults(func=render_cli)
+
+    args = p.parse_args(argv)
+    return args.func(args)
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
