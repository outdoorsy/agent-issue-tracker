+"""tests for dashboard/api/app/data/memory_files.py:read_core_trail
+after the Phase 1b #116 DB cutover."""
+from __future__ import annotations
+
+import sys
+from pathlib import Path
+
+import pytest
+
+# The dashboard module imports as `app.data.memory_files` when run inside
+# the API container; tests need to add the dashboard/api dir to sys.path.
+_DASHBOARD_API = Path(__file__).resolve().parents[1] / "dashboard" / "api"
+sys.path.insert(0, str(_DASHBOARD_API))
+
+from app.data import memory_files
+from scripts.core_trail import write_state
+from scripts.db import connect
+
+
+def _setup_core_trail_db(tmp_path: Path, monkeypatch: pytest.MonkeyPatch,
+                         **row_fields) -> Path:
+    """Pin scripts.db.DB_PATH to a tmp DB, seed it with one core_trail row."""
+    db = tmp_path / "trading.db"
+    monkeypatch.setattr("scripts.db.DB_PATH", db)
+    conn = connect(db)
+    try:
+        write_state(conn, **row_fields)
+    finally:
+        conn.close()
+    return db
+
+
+def test_read_core_trail_returns_db_rows(tmp_path, monkeypatch):
+    _setup_core_trail_db(
+        tmp_path, monkeypatch,
+        symbol="VWCE.DE",
+        ath_close=158.06,
+        ath_close_date="2026-05-06",
+        last_observed=157.98,
+        last_observed_date="2026-05-07",
+        trail_pct=20.0,
+        breach_date=None,
+        re_entry_watch=False,
+        currency="EUR",
+    )
+    entries = memory_files.read_core_trail()
+    assert len(entries) == 1
+    e = entries[0]
+    assert e.symbol == "VWCE.DE"
+    assert e.ath_close == 158.06
+    assert e.ath_close_date == "2026-05-06"
+    assert e.last_observed == 157.98
+    assert e.last_observed_date == "2026-05-07"
+    assert e.trail_pct == 20.0
+    assert e.re_entry_watch is False
+    # Derived fields:
+    assert e.stop == pytest.approx(158.06 * 0.80)
+    assert e.status == "ok"  # 157.98 > stop (~126.45)
+
+
+def test_read_core_trail_derives_status_breached(tmp_path, monkeypatch):
+    _setup_core_trail_db(
+        tmp_path, monkeypatch,
+        symbol="VWCE.DE",
+        ath_close=200.0,
+        ath_close_date="2026-05-01",
+        last_observed=150.0,  # 150 < stop=160 -> breached
+        last_observed_date="2026-05-04",
+        trail_pct=20.0,
+        breach_date="2026-05-03",
+        re_entry_watch=True,
+        currency="EUR",
+    )
+    entries = memory_files.read_core_trail()
+    assert entries[0].status == "breached"
+    assert entries[0].re_entry_watch is True
+
+
+def test_read_core_trail_empty_when_no_rows(tmp_path, monkeypatch):
+    db = tmp_path / "trading.db"
+    monkeypatch.setattr("scripts.db.DB_PATH", db)
+    # connect() creates the schema but no rows
+    conn = connect(db)
+    conn.close()
+    assert memory_files.read_core_trail() == []
+
+
+def test_core_tickers_strips_suffix(tmp_path, monkeypatch):
+    _setup_core_trail_db(
+        tmp_path, monkeypatch,
+        symbol="VWCE.DE",
+        ath_close=158.06,
+        ath_close_date="2026-05-06",
+        last_observed=157.98,
+        last_observed_date="2026-05-07",
+        trail_pct=20.0,
+        breach_date=None,
+        re_entry_watch=False,
+        currency="EUR",
+    )
+    # Flex reports bare "VWCE"; allocation.py needs the stripped form.
+    assert memory_files.core_tickers() == {"VWCE"}
