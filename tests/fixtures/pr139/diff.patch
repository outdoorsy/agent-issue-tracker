+      return write_state(
+          conn,
+          symbol=symbol,
+          ath_close=new.ath_close,
+          ath_close_date=ath_close_date,
+          last_observed=new.last_observed,
+          last_observed_date=observed_date,
+          trail_pct=trail_pct,
+          breach_date=breach_date,
+          re_entry_watch=existing.re_entry_watch,
+          currency=currency or existing.currency,
