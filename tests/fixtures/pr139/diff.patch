+
+
+  # --- Pure-function ratchet (unchanged from pre-#116) -------------------
+
+  @dataclass(frozen=True)
+  class TrailState:
+      ath_close: float       # all-time-high closing price observed
+      stop: float            # current trailing stop = ath_close * (1 - trail_pct/100)
+      last_observed: float   # most recent close
+
+
+  def update_trail(state: TrailState, current_close: float,
+                   trail_pct: float) -> TrailState:
+      """Apply one observation. Returns new immutable state.
+
+      Rule: ath_close ratchets UP only. Stop derives from ath_close and
+      the *current* trail_pct."""
+      if not 0 < trail_pct <= 100:
+          raise ValueError(f"trail_pct must be in (0, 100], got {trail_pct}")
+      new_ath = max(state.ath_close, current_close)
+      new_stop = new_ath * (1 - trail_pct / 100.0)
+      return replace(state, ath_close=new_ath, stop=new_stop,
+                     last_observed=current_close)
+
+
+  def breach_status(state: TrailState) -> str:
+      """One of: 'ok' | 'approaching' | 'breached'.
+
+      'approaching' = within 0.5% of stop (exclusive of breach)."""
+      if state.last_observed < state.stop:
+          return "breached"
+      if state.last_observed < state.stop * 1.005:
+          return "approaching"
+      return "ok"
+
+
+  # --- DB I/O (Phase 1b #116) --------------------------------------------
+
+  def _core_trail_db_path() -> Path | None:
+      """Path passed to db.connect(). None means use the default DB_PATH."""
+      v = os.environ.get("CORE_TRAIL_DB")
+      return Path(v) if v else None
+
+
+  def _core_trail_markdown_path() -> Path:
+      v = os.environ.get("CORE_TRAIL_MARKDOWN")
+      return Path(v) if v else DEFAULT_MARKDOWN
