new file mode 100644
index 0000000..5d37ed0
--- /dev/null
+++ b/scripts/backfill_core_trail.py
@@ -0,0 +1,163 @@
+"""One-shot, idempotent backfill of core_trail from memory/CORE-TRAIL.md.
+
+Re-runs are no-ops: a row's primary key (symbol) already exists in the
+DB; we report it as 'unchanged' and do NOT update. Hand-edited DB rows
+are protected; the backfill is a one-shot seed, not a periodic resync.
+The script remains in the repo as the audit trail of how the DB was seeded.
+
+CLI:
+    python -m scripts.backfill_core_trail
+    python -m scripts.backfill_core_trail --symbol VWCE.DE --dry-run
+"""
+from __future__ import annotations
+
+import argparse
+import datetime as dt
+import re
+import sqlite3
+from pathlib import Path
+
+import yaml
+
+from scripts.db import connect
+
+REPO_ROOT = Path(__file__).resolve().parent.parent
+DEFAULT_MARKDOWN = REPO_ROOT / "memory" / "CORE-TRAIL.md"
+
+_EUR_SUFFIXES = {".DE", ".AS", ".MI", ".PA", ".L", ".SW"}
+_SKIP_HEADERS = {"per-etf format", "behavior"}
+
+
+def infer_currency(symbol: str) -> str:
+    """EUR for EU exchange suffixes; USD otherwise. Single-symbol
+    scope today (VWCE.DE -> EUR); the heuristic is in place for
+    #117/#118 future-proofing."""
+    for suffix in _EUR_SUFFIXES:
+        if symbol.endswith(suffix):
+            return "EUR"
+    return "USD"
+
+
+def parse_markdown(md_path: Path) -> list[dict]:
+    """Parse memory/CORE-TRAIL.md into a list of row dicts. Skips the
+    `Per-ETF format` schema section and the `Behavior` notes section.
+    Each H2 section with a fenced ```yaml block is a candidate row."""
+    text = md_path.read_text(encoding="utf-8")
+    rows: list[dict] = []
+    for sec_match in re.finditer(r"\n## ([^\n]+)\n", text):
+        symbol = sec_match.group(1).strip()
+        if symbol.lower() in _SKIP_HEADERS:
+            continue
+        start = sec_match.end()
+        next_h2 = re.search(r"\n## ", text[start:])
+        section = text[start:start + next_h2.start()] if next_h2 else text[start:]
+        yaml_match = re.search(r"```yaml\s*\n(.*?)\n```", section, re.DOTALL)
+        if not yaml_match:
+            continue
+        try:
+            data = yaml.safe_load(yaml_match.group(1)) or {}
+        except yaml.YAMLError:
+            continue
+        if not isinstance(data, dict):
+            continue
+        # Required date fields: refuse to backfill a half-populated block.
+        # The DB columns are NOT NULL; storing "" here would pass the SQLite
+        # constraint but break any consumer that parses these as ISO dates.
+        # Today VWCE.DE always has both populated; this guard protects
+        # #117/#118 from silently inserting broken rows.
+        for required in ("ath_close_date", "last_observed_date"):
+            if not data.get(required):
+                raise ValueError(
+                    f"{md_path}: '## {symbol}' block is missing required "
+                    f"field {required!r}; refusing to backfill"
+                )
+        rows.append({
+            "symbol": symbol,
+            "ath_close": float(data.get("ath_close") or 0.0),
+            "ath_close_date": str(data["ath_close_date"]),
+            "last_observed": float(data.get("last_observed") or 0.0),
+            "last_observed_date": str(data["last_observed_date"]),
+            "trail_pct": float(data.get("trail_pct") or 20),
+            "breach_date": str(data["breach_date"]) if data.get("breach_date") else None,
+            "re_entry_watch": bool(data.get("re_entry_watch") or False),
+            "currency": infer_currency(symbol),
+        })
+    return rows
+
+
+def backfill(
+    conn: sqlite3.Connection,
+    *,
+    md_path: Path = DEFAULT_MARKDOWN,
+    symbols: tuple[str, ...] | None = None,
+    dry_run: bool = False,
+) -> dict[str, int]:
+    """Read markdown rows; INSERT new symbols, leave existing rows
+    unchanged. Returns {inserted, unchanged, would_insert} (only one of
+    inserted/would_insert is non-zero based on dry_run).
+
+    Idempotency model: primary key is `symbol`; if a symbol already
+    exists in the DB we report it as 'unchanged' and do NOT update.
+    Hand-edited DB rows are protected; the backfill is a one-shot seed,
+    not a periodic resync."""
+    now = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
+    counts = {"inserted": 0, "unchanged": 0, "would_insert": 0}
+    for row in parse_markdown(md_path):
+        if symbols is not None and row["symbol"] not in symbols:
+            continue
+        existing = conn.execute(
+            "SELECT 1 FROM core_trail WHERE symbol=?", (row["symbol"],)
+        ).fetchone()
+        if existing is not None:
+            counts["unchanged"] += 1
+            continue
+        if dry_run:
+            counts["would_insert"] += 1
+            continue
+        with conn:
+            conn.execute(
+                "INSERT INTO core_trail(symbol, ath_close, ath_close_date,"
+                " last_observed, last_observed_date, trail_pct, breach_date,"
+                " re_entry_watch, currency, updated_at) "
+                "VALUES(?,?,?,?,?,?,?,?,?,?)",
+                (
+                    row["symbol"], row["ath_close"], row["ath_close_date"],
+                    row["last_observed"], row["last_observed_date"],
+                    row["trail_pct"], row["breach_date"],
+                    1 if row["re_entry_watch"] else 0,
+                    row["currency"], now,
+                ),
+            )
+        counts["inserted"] += 1
+    return counts
+
+
+def main(argv: list[str] | None = None) -> int:
+    p = argparse.ArgumentParser(
+        description="One-shot core_trail backfill from markdown."
+    )
+    p.add_argument("--symbol", default=None,
+                   help="restrict to one symbol (default: all)")
+    p.add_argument("--dry-run", action="store_true",
+                   help="report what would be inserted, write nothing")
+    p.add_argument("--markdown", type=Path, default=DEFAULT_MARKDOWN,
+                   help=f"override path (default: {DEFAULT_MARKDOWN})")
+    args = p.parse_args(argv)
+    symbols = (args.symbol,) if args.symbol else None
+    conn = connect()
+    try:
+        counts = backfill(conn, md_path=args.markdown,
+                          symbols=symbols, dry_run=args.dry_run)
+    finally:
+        conn.close()
+    if args.dry_run:
+        print(f"would insert {counts['would_insert']} row(s); "
+              f"{counts['unchanged']} already present")
+    else:
+        print(f"inserted {counts['inserted']} row(s); "
+              f"{counts['unchanged']} already present")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
