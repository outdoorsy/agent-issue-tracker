+"""tests for scripts.core_trail.render -- markdown view of core_trail rows."""
+from __future__ import annotations
+
+from pathlib import Path
+
+from scripts.core_trail import render, write_state
+from scripts.db import connect
+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+CORE_TRAIL_MD = REPO_ROOT / "memory" / "CORE-TRAIL.md"
+
+
+def _seed_vwce(conn) -> None:
+    write_state(
+        conn,
+        symbol="VWCE.DE",
+        ath_close=158.06,
+        ath_close_date="2026-05-06",
+        last_observed=157.98,
+        last_observed_date="2026-05-07",
+        trail_pct=20.0,
+        breach_date=None,
+        re_entry_watch=False,
+        currency="EUR",
+    )
+
+
+def test_render_byte_identical_to_committed_markdown(tmp_path: Path):
+    """render(conn) output equals the committed memory/CORE-TRAIL.md
+    byte-for-byte after the Task 6 cutover commit. (Pre-cutover this
+    test fails by design -- the cutover commit fixes it.)"""
+    conn = connect(tmp_path / "t.db")
+    try:
+        _seed_vwce(conn)
+        rendered = render(conn)
+    finally:
+        conn.close()
+    # Guard against CRLF contamination: read_text() universal-newlines
+    # silently normalizes \r\n to \n, which would mask a bad on-disk
+    # file. Check the raw bytes first, then compare text.
+    raw = CORE_TRAIL_MD.read_bytes()
+    assert b"\r\n" not in raw, "memory/CORE-TRAIL.md must have LF line endings"
+    committed = CORE_TRAIL_MD.read_text(encoding="utf-8")
+    assert rendered == committed
+
+
+def test_render_derives_stop_and_status(tmp_path: Path):
+    conn = connect(tmp_path / "t.db")
+    try:
+        write_state(
+            conn, symbol="TEST", ath_close=200.0,
+            ath_close_date="2026-05-01", last_observed=180.0,
+            last_observed_date="2026-05-02", trail_pct=20.0,
+            breach_date=None, re_entry_watch=False, currency="USD",
+        )
+        out = render(conn)
+    finally:
+        conn.close()
+    # Derived stop = 200 * 0.80 = 160.00
+    assert "stop: 160.00" in out
+    # 180 > stop=160 -> status: ok
+    assert "status: ok" in out
+
+
+def test_render_status_approaching_within_band(tmp_path: Path):
+    """0.5% band above stop renders as `status: approaching`. Pure-fn
+    coverage in test_core_trail.py exercises the threshold; this is the
+    render-layer guard that the derived `status` field flows through."""
+    conn = connect(tmp_path / "t.db")
+    try:
+        # ath=200, trail=20 -> stop=160. 160.4 is 0.25% above stop -> approaching.
+        write_state(
+            conn, symbol="TEST", ath_close=200.0,
+            ath_close_date="2026-05-01", last_observed=160.4,
+            last_observed_date="2026-05-02", trail_pct=20.0,
+            breach_date=None, re_entry_watch=False, currency="USD",
+        )
+        out = render(conn)
+    finally:
+        conn.close()
+    assert "status: approaching" in out
+
+
+def test_render_status_breached_when_below_stop(tmp_path: Path):
+    conn = connect(tmp_path / "t.db")
+    try:
+        write_state(
+            conn, symbol="TEST", ath_close=200.0,
+            ath_close_date="2026-05-01", last_observed=150.0,
+            last_observed_date="2026-05-04", trail_pct=20.0,
+            breach_date="2026-05-03", re_entry_watch=True, currency="USD",
+        )
+        out = render(conn)
+    finally:
+        conn.close()
+    assert "status: breached" in out
+    assert "breach_date: 2026-05-03" in out
+    assert "re_entry_watch: true" in out
+
+
+def test_render_multi_symbol_alphabetical_ordering(tmp_path: Path):
+    conn = connect(tmp_path / "t.db")
+    try:
+        write_state(
+            conn, symbol="ZZZZ.DE", ath_close=100.0,
+            ath_close_date="2026-05-01", last_observed=95.0,
+            last_observed_date="2026-05-02", trail_pct=20.0,
+            breach_date=None, re_entry_watch=False, currency="EUR",
+        )
+        write_state(
+            conn, symbol="AAAA.DE", ath_close=100.0,
+            ath_close_date="2026-05-01", last_observed=95.0,
+            last_observed_date="2026-05-02", trail_pct=20.0,
+            breach_date=None, re_entry_watch=False, currency="EUR",
+        )
+        out = render(conn)
+    finally:
+        conn.close()
+    assert out.index("## AAAA.DE") < out.index("## ZZZZ.DE")
+
+
+def test_render_empty_db_still_produces_intro_and_behavior(tmp_path: Path):
+    conn = connect(tmp_path / "t.db")
+    try:
+        out = render(conn)
+    finally:
+        conn.close()
+    assert "# Core ETF Trailing Stop -- current state" in out
+    assert "DB-canonical" in out
+    assert "## Behavior" in out
+    # No per-symbol H2 sections beyond the schema/notes ones.
+    assert out.count("## ") == 2  # "Per-ETF format", "Behavior"
+
+
+def test_render_cli_stdout(tmp_path: Path):
+    """`python -m scripts.core_trail render` writes to stdout."""
+    import os
+    import subprocess
+    import sys
+    env = {**os.environ, "CORE_TRAIL_DB": str(tmp_path / "t.db")}
+    conn = connect(tmp_path / "t.db")
